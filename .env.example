# Copy to .env and fill in only what you have. NOTHING here is required to run
# the default pipeline — the free US Census geocoder needs no key.
# Never commit the real .env (it is gitignored).

# Optional paid geocoder keys (pluggable backends; lab may supply later):
# GOOGLE_MAPS_API_KEY=
# MAPBOX_ACCESS_TOKEN=

# Free EIA Open Data key (only for the EIA collector): https://www.eia.gov/opendata/
# EIA_API_KEY=

# Optional free PeeringDB API key (raises rate limits; anonymous access is throttled):
# create one at https://www.peeringdb.com/ -> Profile -> API Keys
# PEERINGDB_API_KEY=
